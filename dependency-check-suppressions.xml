<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        OWASP Dependency Check Suppressions

        Add suppressions here for known false positives or accepted risks.
        Each suppression should include:
        - Why the vulnerability is suppressed
        - When it was suppressed
        - Who approved the suppression

        Example:
        <suppress>
            <notes><![CDATA[
            CVE is for a different component with the same name.
            Reviewed and approved by Security Team on 2026-05-27.
            ]]></notes>
            <cve>CVE-2024-XXXXX</cve>
        </suppress>
    -->

    <!-- False positive: CVE-2025-7962 affects angus-mail, not angus-activation -->
    <suppress>
        <notes><![CDATA[
        CVE-2025-7962 is wrongly reported for angus-activation.
        The vulnerability affects angus-mail (Jakarta Mail), not angus-activation (Jakarta Activation).
        These are separate projects with independent versioning.
        See: https://github.com/dependency-check/DependencyCheck/issues/8144
        Reviewed and approved by Scot P. Floess on 2026-05-27.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.eclipse\.angus/angus\-activation@.*$</packageUrl>
        <cve>CVE-2025-7962</cve>
    </suppress>
</suppressions>
